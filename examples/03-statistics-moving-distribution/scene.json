{
  "$schema": "geogebra-anim/v1",
  "title": "statistics-moving-distribution",
  "app": "classic",
  "view": {
    "coords": [-3.6, 3.6, -0.4, 3.6],
    "axes": true,
    "grid": false,
    "axisRatio": [1, 1]
  },
  "objects": [
    "t = Slider(0, 2*pi, 0.02, 0.55, 200, false, true, true, false)",
    "x1 = -2.6",
    "x2 = -1.55",
    "x3 = -0.5",
    "x4 = 0.55",
    "x5 = 1.6",
    "x6 = 2.55",
    "h1 = 1.2 + 0.55*sin(t)",
    "h2 = 1.45 + 0.55*sin(t + 0.9)",
    "h3 = 1.75 + 0.65*sin(t + 1.8)",
    "h4 = 1.65 + 0.6*sin(t + 2.7)",
    "h5 = 1.35 + 0.55*sin(t + 3.6)",
    "h6 = 1.1 + 0.5*sin(t + 4.5)",
    "total = h1 + h2 + h3 + h4 + h5 + h6",
    "mu = (x1*h1 + x2*h2 + x3*h3 + x4*h4 + x5*h5 + x6*h6)/total",
    "sigma = sqrt(((x1 - mu)^2*h1 + (x2 - mu)^2*h2 + (x3 - mu)^2*h3 + (x4 - mu)^2*h4 + (x5 - mu)^2*h5 + (x6 - mu)^2*h6)/total)",
    "M = (mu, 0)",
    "MeanTop = (mu, 3.25)",
    "BA1 = (-3.05, 0)",
    "BB1 = (-2.15, 0)",
    "BC1 = (-2.15, h1)",
    "BD1 = (-3.05, h1)",
    "BA2 = (-2.0, 0)",
    "BB2 = (-1.1, 0)",
    "BC2 = (-1.1, h2)",
    "BD2 = (-2.0, h2)",
    "BA3 = (-0.95, 0)",
    "BB3 = (-0.05, 0)",
    "BC3 = (-0.05, h3)",
    "BD3 = (-0.95, h3)",
    "BA4 = (0.1, 0)",
    "BB4 = (1.0, 0)",
    "BC4 = (1.0, h4)",
    "BD4 = (0.1, h4)",
    "BA5 = (1.15, 0)",
    "BB5 = (2.05, 0)",
    "BC5 = (2.05, h5)",
    "BD5 = (1.15, h5)",
    "BA6 = (2.2, 0)",
    "BB6 = (3.1, 0)",
    "BC6 = (3.1, h6)",
    "BD6 = (2.2, h6)",
    "bar1 = Polygon(BA1, BB1, BC1, BD1)",
    "bar2 = Polygon(BA2, BB2, BC2, BD2)",
    "bar3 = Polygon(BA3, BB3, BC3, BD3)",
    "bar4 = Polygon(BA4, BB4, BC4, BD4)",
    "bar5 = Polygon(BA5, BB5, BC5, BD5)",
    "bar6 = Polygon(BA6, BB6, BC6, BD6)",
    "meanLine = Segment(M, MeanTop)",
    "bell = Curve(u, 1.75*exp(-((u - mu)^2)/(2*sigma^2)), u, -3.2, 3.2)",
    "SetVisibleInView(MeanTop, 1, false)",
    "SetVisibleInView(BA1, 1, false)",
    "SetVisibleInView(BB1, 1, false)",
    "SetVisibleInView(BC1, 1, false)",
    "SetVisibleInView(BD1, 1, false)",
    "SetVisibleInView(BA2, 1, false)",
    "SetVisibleInView(BB2, 1, false)",
    "SetVisibleInView(BC2, 1, false)",
    "SetVisibleInView(BD2, 1, false)",
    "SetVisibleInView(BA3, 1, false)",
    "SetVisibleInView(BB3, 1, false)",
    "SetVisibleInView(BC3, 1, false)",
    "SetVisibleInView(BD3, 1, false)",
    "SetVisibleInView(BA4, 1, false)",
    "SetVisibleInView(BB4, 1, false)",
    "SetVisibleInView(BC4, 1, false)",
    "SetVisibleInView(BD4, 1, false)",
    "SetVisibleInView(BA5, 1, false)",
    "SetVisibleInView(BB5, 1, false)",
    "SetVisibleInView(BC5, 1, false)",
    "SetVisibleInView(BD5, 1, false)",
    "SetVisibleInView(BA6, 1, false)",
    "SetVisibleInView(BB6, 1, false)",
    "SetVisibleInView(BC6, 1, false)",
    "SetVisibleInView(BD6, 1, false)",
    "SetColor(bar1, \"#4C78A8\")",
    "SetColor(bar2, \"#72B7B2\")",
    "SetColor(bar3, \"#54A24B\")",
    "SetColor(bar4, \"#F58518\")",
    "SetColor(bar5, \"#E45756\")",
    "SetColor(bar6, \"#B279A2\")",
    "SetFilling(bar1, 0.55)",
    "SetFilling(bar2, 0.55)",
    "SetFilling(bar3, 0.55)",
    "SetFilling(bar4, 0.55)",
    "SetFilling(bar5, 0.55)",
    "SetFilling(bar6, 0.55)",
    "SetColor(meanLine, \"#111827\")",
    "SetLineThickness(meanLine, 4)",
    "SetColor(M, \"#111827\")",
    "SetPointSize(M, 7)",
    "SetTrace(M, true)",
    "SetColor(bell, \"#E45756\")",
    "SetLineThickness(bell, 4)"
  ],
  "animate": [
    { "target": "t", "speed": 0.55, "direction": "increasing" }
  ],
  "autoplay": true,
  "captureAt": 0,
  "notes": "Statistics example: six grouped frequencies change periodically while the weighted mean mu and standard deviation sigma are recomputed live. A mean line and bell curve show the changing distribution shape."
}
