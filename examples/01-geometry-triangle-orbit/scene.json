{
  "$schema": "geogebra-anim/v1",
  "title": "geometry-triangle-orbit",
  "app": "classic",
  "view": {
    "coords": [-3.6, 3.6, -2.6, 2.6],
    "axes": true,
    "grid": false,
    "axisRatio": [1, 1]
  },
  "objects": [
    "t = Slider(0, 2*pi, 0.02, 0.65, 200, false, true, true, false)",
    "O = (0, 0)",
    "A = (2.6*cos(t), 1.7*sin(t))",
    "B = (2.2*cos(t + 2*pi/3) + 0.35*cos(2*t), 1.8*sin(t + 2*pi/3))",
    "C = (2.4*cos(t + 4*pi/3), 1.5*sin(t + 4*pi/3) + 0.45*sin(2*t))",
    "tri = Polygon(A, B, C)",
    "MAB = Midpoint(A, B)",
    "MBC = Midpoint(B, C)",
    "MCA = Midpoint(C, A)",
    "ma = Segment(A, MBC)",
    "mb = Segment(B, MCA)",
    "mc = Segment(C, MAB)",
    "G = ((x(A) + x(B) + x(C))/3, (y(A) + y(B) + y(C))/3)",
    "circ = Circle(A, B, C)",
    "gPath = Curve((2.6*cos(u) + 2.2*cos(u + 2*pi/3) + 0.35*cos(2*u) + 2.4*cos(u + 4*pi/3))/3, (1.7*sin(u) + 1.8*sin(u + 2*pi/3) + 1.5*sin(u + 4*pi/3) + 0.45*sin(2*u))/3, u, 0, 2*pi)",
    "SetColor(tri, \"#4C78A8\")",
    "SetFilling(tri, 0.18)",
    "SetLineThickness(tri, 3)",
    "SetColor(circ, \"#F58518\")",
    "SetLineThickness(circ, 2)",
    "SetColor(ma, \"#54A24B\")",
    "SetColor(mb, \"#54A24B\")",
    "SetColor(mc, \"#54A24B\")",
    "SetLineStyle(ma, 1)",
    "SetLineStyle(mb, 1)",
    "SetLineStyle(mc, 1)",
    "SetColor(gPath, \"#B279A2\")",
    "SetLineThickness(gPath, 3)",
    "SetColor(G, \"#E45756\")",
    "SetPointSize(G, 7)",
    "SetTrace(G, true)",
    "SetColor(A, \"#1F77B4\")",
    "SetColor(B, \"#1F77B4\")",
    "SetColor(C, \"#1F77B4\")",
    "SetPointSize(A, 5)",
    "SetPointSize(B, 5)",
    "SetPointSize(C, 5)"
  ],
  "animate": [
    { "target": "t", "speed": 0.65, "direction": "increasing" }
  ],
  "autoplay": true,
  "captureAt": 0,
  "notes": "Geometry example: triangle vertices move on phase-shifted orbits while the circumcircle, medians, and centroid update together. Centroid G has trace enabled, and gPath shows the full centroid path."
}
