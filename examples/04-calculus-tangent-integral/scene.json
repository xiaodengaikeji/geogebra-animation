{
  "$schema": "geogebra-anim/v1",
  "title": "calculus-tangent-integral",
  "app": "classic",
  "view": {
    "coords": [-3.2, 3.2, -1.2, 4.2],
    "axes": true,
    "grid": true,
    "axisRatio": [1, 1]
  },
  "objects": [
    "t = Slider(-2.45, 2.45, 0.02, 0.65, 200, false, true, true, false)",
    "f(x) = 0.12*x^3 - 0.45*x + 1.8",
    "df(x) = 0.36*x^2 - 0.45",
    "P = (t, f(t))",
    "D = (t, df(t))",
    "q(x) = f(t) + df(t)*(x - t)",
    "area = Integral(f, -2.45, t)",
    "LeftBase = (-2.45, 0)",
    "Foot = (t, 0)",
    "base = Segment(LeftBase, Foot)",
    "height = Segment(Foot, P)",
    "A = (-2.8, f(-2.8))",
    "lSec = Line(A, P)",
    "SetVisibleInView(LeftBase, 1, false)",
    "SetVisibleInView(Foot, 1, false)",
    "SetColor(f, \"#4C78A8\")",
    "SetLineThickness(f, 5)",
    "SetColor(df, \"#72B7B2\")",
    "SetLineThickness(df, 3)",
    "SetLineStyle(df, 1)",
    "SetColor(q, \"#E45756\")",
    "SetLineThickness(q, 4)",
    "SetColor(area, \"#F58518\")",
    "SetFilling(area, 0.35)",
    "SetColor(base, \"#9D755D\")",
    "SetLineThickness(base, 3)",
    "SetColor(height, \"#9D755D\")",
    "SetLineStyle(height, 2)",
    "SetColor(lSec, \"#B279A2\")",
    "SetLineStyle(lSec, 1)",
    "SetColor(P, \"#E45756\")",
    "SetPointSize(P, 7)",
    "SetTrace(P, true)",
    "SetColor(D, \"#72B7B2\")",
    "SetPointSize(D, 6)",
    "SetTrace(D, true)"
  ],
  "animate": [
    { "target": "t", "speed": 0.65, "direction": "increasing" }
  ],
  "autoplay": true,
  "captureAt": 0,
  "notes": "Calculus example: point P moves along the function curve and the tangent is driven by derivative df(t). The area object shows the integral from the left endpoint to t, while D tracks the matching point on the derivative curve."
}
