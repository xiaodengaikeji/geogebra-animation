{
  "$schema": "geogebra-anim/v1",
  "title": "algebra-cubic-roots",
  "app": "classic",
  "view": {
    "coords": [-4, 4, -4, 4],
    "axes": true,
    "grid": true,
    "axisRatio": [1, 1]
  },
  "objects": [
    "t = Slider(0, 2*pi, 0.02, 0.7, 200, false, true, true, false)",
    "a = -1.35 + 0.85*sin(t)",
    "b = 1.25 + 0.95*cos(t)",
    "x0 = 2.35*cos(t)",
    "f(x) = ((x - a)*(x + 2)*(x - b))/3",
    "df(x) = ((x + 2)*(x - b) + (x - a)*(x - b) + (x - a)*(x + 2))/3",
    "q(x) = f(x0) + df(x0)*(x - x0)",
    "R1 = (a, 0)",
    "R2 = (-2, 0)",
    "R3 = (b, 0)",
    "T = (x0, f(x0))",
    "X0 = (x0, 0)",
    "V = Segment(X0, T)",
    "rootSpan = Segment(R1, R3)",
    "control = (a, b)",
    "SetColor(f, \"#4C78A8\")",
    "SetLineThickness(f, 5)",
    "SetColor(df, \"#72B7B2\")",
    "SetLineThickness(df, 2)",
    "SetLineStyle(df, 1)",
    "SetColor(q, \"#E45756\")",
    "SetLineThickness(q, 4)",
    "SetColor(R1, \"#F58518\")",
    "SetColor(R2, \"#F58518\")",
    "SetColor(R3, \"#F58518\")",
    "SetPointSize(R1, 7)",
    "SetPointSize(R2, 7)",
    "SetPointSize(R3, 7)",
    "SetColor(T, \"#E45756\")",
    "SetPointSize(T, 7)",
    "SetTrace(T, true)",
    "SetVisibleInView(X0, 1, false)",
    "SetColor(V, \"#9D755D\")",
    "SetLineStyle(V, 2)",
    "SetColor(rootSpan, \"#F58518\")",
    "SetLineThickness(rootSpan, 3)",
    "SetColor(control, \"#B279A2\")",
    "SetPointSize(control, 6)",
    "SetTrace(control, true)"
  ],
  "animate": [
    { "target": "t", "speed": 0.7, "direction": "increasing" }
  ],
  "autoplay": true,
  "captureAt": 0,
  "notes": "Algebra example: two roots of a cubic move with t while the third root stays fixed at -2. The function, derivative, moving tangent, root span, and parameter control point update together."
}
